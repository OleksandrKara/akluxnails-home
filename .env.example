# Shared Postgres `marketing` schema — owned/migrated by the salonLandings repo. This app only
# reads/writes rows in tables that already exist there (landing_pages, landing_variants, visits,
# events); it never runs its own migrations against that schema.
MARKETING_DB_HOST=postgres
MARKETING_DB_PORT=5432
MARKETING_DB_NAME=salonreview
MARKETING_DB_USER=salon
MARKETING_DB_PASSWORD=

# Slug of this app's row in marketing.landing_pages.
LANDING_PAGE_SLUG=home

# Fallback booking link (e.g. footer/contact section) — the homepage's own native booking flow
# (Square-backed, see lib/square/) is the primary path now; this is no longer the main "Book Now".
NEXT_PUBLIC_BOOKING_URL=https://mani.akluxnails.com

# Square — same production account/location as salonLandings (mani.akluxnails.com), called
# independently from this app's own server. Set SQUARE_ENVIRONMENT=sandbox to point this whole app
# at Square's Sandbox for safe end-to-end testing (especially of the card-on-file step).
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=

# Client-side (Web Payments SDK) card-on-file config. NEXT_PUBLIC_SQUARE_LOCATION_ID is the same,
# non-secret value as SQUARE_LOCATION_ID above. NEXT_PUBLIC_SQUARE_APPLICATION_ID is public too
# (visible in the browser regardless) — from Square Developer Dashboard > your app > Credentials.
NEXT_PUBLIC_SQUARE_ENVIRONMENT=production
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
